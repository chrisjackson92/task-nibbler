# Task Nibbles — Local Development Environment
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/task_nibbles?sslmode=disable
JWT_SECRET=local-dev-jwt-secret-change-in-prod-must-be-256-bits
JWT_REFRESH_SECRET=local-dev-jwt-refresh-secret-change-in-prod
AWS_ACCESS_KEY_ID=your-dev-access-key
AWS_SECRET_ACCESS_KEY=your-dev-secret-key
AWS_S3_BUCKET=task-nibbles-attachments-dev
AWS_REGION=us-east-1
RESEND_API_KEY=re_test_xxxx
RESEND_FROM_EMAIL=Task Nibbles <noreply@tasknibbles.com>
APP_BASE_URL=http://localhost:3000
PORT=8080
APP_ENV=development
LOG_LEVEL=debug
